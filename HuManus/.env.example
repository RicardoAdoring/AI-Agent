APP_NAME=HuManus
APP_HOST=0.0.0.0
APP_PORT=8123

LLM_PROVIDER=openai_compatible
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
ENABLE_OLLAMA_FALLBACK=true

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

CHAT_MEMORY_DIR=./data/chat_memory
MAX_HISTORY_MESSAGES=20

RAG_ENABLED=true
RAG_KNOWLEDGE_DIR=./data/knowledge
RAG_INDEX_DIR=./data/rag
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_DIMENSIONS=0
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RAG_ALLOW_HASH_EMBEDDING=false
RAG_AUTO_BUILD=true
RAG_SCORE_THRESHOLD=0.15
RAG_REQUIRE_INDEX_CONFIG_MATCH=true

MANUS_ENABLED=true
MANUS_MAX_STEPS=20
MANUS_WORKSPACE_DIR=./data/manus/workspace
MANUS_OUTPUT_DIR=./data/manus/output
MANUS_DOWNLOAD_DIR=./data/manus/downloads
MANUS_LOG_DIR=./logger
MANUS_ALLOW_PRIVATE_URLS=false
MANUS_HTTP_TIMEOUT_SECONDS=15
MANUS_MAX_DOWNLOAD_BYTES=10485760
MANUS_SEARCH_PROVIDER=searchapi
MANUS_SEARCH_API_KEY=
MANUS_SEARCH_BASE_URL=https://www.searchapi.io/api/v1/search
MANUS_SEARCH_ENGINE=baidu
MANUS_SEARCH_TOP_K=5

MCP_ENABLED=false
MCP_CONFIG_PATH=../mcp.json
MCP_TOOL_CALL_TIMEOUT_SECONDS=30
AMAP_MAPS_API_KEY=

AGENT_BACKEND=langgraph
AGENT_CHECKPOINT_PATH=./data/manus/checkpoints.sqlite
